# Kira Sandbox Credentials — example file (NOT a real .env)
#
# Copy this file to `.env` (which is gitignored) and fill in the values
# Kira provides you when you onboard as a sandbox integration partner.
#
# Source: Kira contact / partner onboarding (the partner-distributed
# `kira-sandbox-integration-guide.docx` calls out where to obtain them).
#
# Used by: evidence/work/run_flow.py + every probe script under evidence/work/probes/

# --- Credentials (do NOT commit real values) ---
KIRA_CLIENT_ID=<your-uuid-v4-client-id>
KIRA_API_KEY=<your-api-key>
KIRA_COGNITO_SECRET=<your-cognito-secret-aka-password-in-docs>

# --- Sandbox base URL ---
# Empirical truth (Phase 2 DRIFT-1): the working base is https://api.balampay.com
# (no `/sandbox` prefix), even though both the public docs and the partner
# integration guide claim `/sandbox/...`. See evidence/analysis/04-integration-log.md DRIFT-1.
KIRA_API_BASE_URL=https://api.balampay.com
